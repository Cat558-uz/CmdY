local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")

local ADMINS = {
	["admin202078"] = true,
	["BK_FAXBR"] = true,
  ["kit_cynALT"] = true,
	["TUBERS93_HACKER56"] = true
}

local BAN_FILE = "banlist.txt"
local BanList = {}

--== Leitura do arquivo de bans ==--
if isfile(BAN_FILE) then
	local data = readfile(BAN_FILE)
	for name in string.gmatch(data, "([^,]+)") do
		BanList[name] = true
	end
else
	writefile(BAN_FILE, "")
end

local function saveBanList()
	local all = {}
	for name in pairs(BanList) do
		table.insert(all, name)
	end
	writefile(BAN_FILE, table.concat(all, ","))
end

local function isAdmin(player)
	return player and ADMINS[player.Name] == true
end

local function findPlayerByName(query)
	if not query then return nil end
	query = query:lower()
	for _, p in pairs(Players:GetPlayers()) do
		if p.Name:lower() == query or (p.DisplayName and p.DisplayName:lower() == query) then
			return p
		end
	end
	for _, p in pairs(Players:GetPlayers()) do
		if p.Name:lower():find(query) or (p.DisplayName and p.DisplayName:lower():find(query)) then
			return p
		end
	end
	return nil
end

local function kickPlayer(target, reason)
	if not target then return end
	pcall(function()
		target:Kick(reason or "Expulso pelo admin")
	end)
end

local function killPlayer(target)
	if not target then return end
	local char = target.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then hum.Health = 0 end
end

local function sendChatMessage(message)
	if TextChatService.ChatInputBarConfiguration
	and TextChatService.ChatInputBarConfiguration.TargetTextChannel then
		local canal = TextChatService.ChatInputBarConfiguration.TargetTextChannel
		canal:SendAsync(message)
	end
end

local function bringPlayer(adminPlayer, target)
	if not adminPlayer or not target then return end
	local aChar, tChar = adminPlayer.Character, target.Character
	if not aChar or not tChar then return end
	local aHRP = aChar:FindFirstChild("HumanoidRootPart")
	local tHRP = tChar:FindFirstChild("HumanoidRootPart")
	if not aHRP or not tHRP then return end

	tHRP.CFrame = aHRP.CFrame * CFrame.new(0, 0, -2)
end

local function flingPlayer(target, minForce, maxForce)
	if not target or not target.Character then return end
	local hrp = target.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local dir = Vector3.new(math.random(-1,1), math.random(1,2), math.random(-1,1)).Unit
	local vel = Instance.new("BodyVelocity", hrp)
	vel.Velocity = dir * math.random(minForce or 40, maxForce or 80)
	vel.MaxForce = Vector3.new(1e6, 1e6, 1e6)
	game.Debris:AddItem(vel, 0.5)
end

--== Sistema de comandos ==--
local function onChat(player, msg)
	if not isAdmin(player) then return end
	local cmd, arg = msg:match("^%s*(;[%w_]+)%s*(.-)%s*$")
	if not cmd then return end
	cmd = cmd:lower()

	if cmd == ";kill" and arg ~= "" then
		local alvo = findPlayerByName(arg)
		if alvo then killPlayer(alvo) end

	elseif cmd == ";kick" and arg ~= "" then
		local alvo = findPlayerByName(arg)
		if alvo then
			sendChatMessage("sucess")
    wait(0.2)
			kickPlayer(alvo)
    game:Shutdown()
		end

	elseif cmd == ";bring" and arg ~= "" then
		local alvo = findPlayerByName(arg)
		if alvo then bringPlayer(player, alvo) end

	elseif cmd == ";fling" and arg ~= "" then
		local alvo = findPlayerByName(arg)
		if alvo then flingPlayer(alvo) end

elseif cmd == ";freeze" and arg ~= "" then
	local alvo = findPlayerByName(arg)
	if alvo and alvo.Character and alvo.Character:FindFirstChild("HumanoidRootPart") then
		local hrp = alvo.Character.HumanoidRootPart
		local hum = alvo.Character:FindFirstChildOfClass("Humanoid")
		Frozen = Frozen or {}
		Frozen[alvo.Name] = true

		-- força e prende o player
		local bv = Instance.new("BodyVelocity")
		bv.Velocity = Vector3.new(0, 0, 0)
		bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
		bv.Name = "FreezeForce"
		bv.Parent = hrp

		if hum then
			hum.WalkSpeed = 0
			hum.JumpPower = 0
			hum.PlatformStand = true
		end

		alvo.CharacterAdded:Connect(function(char)
			if Frozen[alvo.Name] then
				task.wait(0.2)
				local nhrp = char:WaitForChild("HumanoidRootPart", 5)
				local nhum = char:FindFirstChildOfClass("Humanoid")
				if nhrp then
					local nbv = Instance.new("BodyVelocity")
					nbv.Velocity = Vector3.new(0, 0, 0)
					nbv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
					nbv.Name = "FreezeForce"
					nbv.Parent = nhrp
				end
				if nhum then
					nhum.WalkSpeed = 0
					nhum.JumpPower = 0
					nhum.PlatformStand = true
				end
			end
		end)
	end

elseif cmd == ";unfreeze" and arg ~= "" then
	local alvo = findPlayerByName(arg)
	if alvo and alvo.Character and alvo.Character:FindFirstChild("HumanoidRootPart") then
		local hrp = alvo.Character.HumanoidRootPart
		local hum = alvo.Character:FindFirstChildOfClass("Humanoid")
		Frozen = Frozen or {}
		Frozen[alvo.Name] = nil

		for _, v in pairs(hrp:GetChildren()) do
			if v:IsA("BodyVelocity") and v.Name == "FreezeForce" then
				v:Destroy()
			end
		end

		if hum then
			hum.WalkSpeed = 16
			hum.JumpPower = 50
			hum.PlatformStand = false
		end
	end


 elseif cmd == ";unfly" and arg ~= "" then
	local alvo = findPlayerByName(arg)
	if alvo and alvo.Character then
		local char = alvo.Character
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		local hrp = char:FindFirstChild("HumanoidRootPart")

		local function remove_movers(root)
			local classes = {
				BodyVelocity=true, BodyGyro=true, BodyForce=true, BodyThrust=true, BodyPosition=true,
				BodyAngularVelocity=true, VectorForce=true, LinearVelocity=true, AlignPosition=true,
				AlignOrientation=true, RocketPropulsion=true
			}
			for _, v in pairs(root:GetDescendants()) do
				if v and classes[v.ClassName] then
					pcall(function() v:Destroy() end)
				end
			end
		end

		local function disable_connections(obj)
			pcall(function()
				if typeof(getconnections) == "function" then
					for _, c in pairs(getconnections(obj)) do
						pcall(function()
							if c.Disconnect then c:Disconnect()
							elseif c.Disable then c:Disable() end
						end)
					end
				end
			end)
		end

		if hrp then
			pcall(function() hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end)
			remove_movers(hrp)
			disable_connections(hrp)
		end

		if char then
			remove_movers(char)
			disable_connections(char)
		end

		if humanoid then
			pcall(function()
				humanoid.PlatformStand = false
				humanoid.WalkSpeed = 16
				if humanoid.JumpPower ~= nil then humanoid.JumpPower = 50 end
				if humanoid.JumpHeight ~= nil then humanoid.JumpHeight = 7.2 end
				humanoid:ChangeState(Enum.HumanoidStateType.Running)
			end)
		end

		pcall(function() workspace.Gravity = 196.2 end)
