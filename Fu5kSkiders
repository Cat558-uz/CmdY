-- cmd silent (RPName)
local lastBio = {}

local function getRPName(player)
	local bag = player:FindFirstChild("PlayersBag")
	if bag then
		local rp = bag:FindFirstChild("RPName")
		if rp and rp.Value then
			return tostring(rp.Value)
		end
	end
end

local function checkRPCommand(player)
	if not isAdmin(player) then return end

	local texto = getRPName(player)
	if not texto or texto == "" then return end

	if lastBio[player] == texto then return end
	lastBio[player] = texto

	local cmd,args = texto:match("^%s*;(%S+)%s*(.*)$")
	if not cmd then return end

	cmd = cmd:lower()
	local c = Commands[cmd]

	if c then
		c(player,args)
	end
end

task.spawn(function()
	while true do
		for _,p in pairs(Players:GetPlayers()) do
			checkRPCommand(p)
		end
		task.wait(0.25)
	end
end)

-- chat tag
TextChatService.OnIncomingMessage = function(message)
	local props = Instance.new("TextChatMessageProperties")

	if message.TextSource then
		local player = Players:GetPlayerByUserId(message.TextSource.UserId)
		if player and ADMINS[player.Name] then
			props.PrefixText = "<font color='#ffff00'>[Owner script]</font> "..message.PrefixText
		end
	end

	return props
end
