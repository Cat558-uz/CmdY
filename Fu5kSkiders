local function onChat(player,msg)
	if not isAdmin(player) then return end

	local cmd,args = msg:match("^%s*;(%S+)%s*(.*)$")
	if not cmd then return end

	cmd = cmd:lower()

	local c = Commands[cmd]
	if c then
		c(player,args)
	end
end

